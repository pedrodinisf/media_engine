# media_engine — operator-managed secret store.
#
# Materialized to deploy/hetzner/secrets.env by bootstrap.sh (chmod
# 0600, chowned to the container's `engine` user uid). Mounted
# read-write into the container at
#   /home/engine/.config/media_engine/secrets.env
# and auto-loaded by EngineConfig.load BEFORE settings parsing — see
# media_engine/runtime/secrets.py.
#
# The Settings → Secrets tab in the Web UI reads and writes THIS SAME
# FILE in place, so post-deploy rotation never requires editing the
# host or restarting containers.
#
# All keys are optional; an empty key just disables the ops that
# depend on it (visible in `med doctor`).

# ─── Cloud LLM / VLM ────────────────────────────────────────────
# Canonical name is GEMINI_API_KEY (not GOOGLE_API_KEY).
GEMINI_API_KEY=
# Used by intelligence.extract (claude router) and downstream ops
# that route through it (intelligence.summarize/classify/analyze).
ANTHROPIC_API_KEY=
# Reserved for future OpenAI-routed ops.
OPENAI_API_KEY=

# ─── Model gating ───────────────────────────────────────────────
# Hugging Face access token. Pyannote (audio.diarize) gates several
# of its models behind a licence-acceptance flow that requires a
# token. Leave blank to skip diarize.
HF_TOKEN=

# ─── Optional remote search backends ────────────────────────────
# Point search.fulltext / search.semantic at a separate Postgres
# (otherwise they share the main cache DB).
MEDIA_ENGINE_FULLTEXT_DB_URL=
MEDIA_ENGINE_SEMANTIC_DB_URL=

# ─── Optional: Caddy DNS-01 wildcard cert ───────────────────────
# Only needed when the wildcard override is active (see handbook
# §3.1 and deploy/hetzner/docker-compose.wildcard.yaml). Scoped to
# Zone:DNS:Edit on the zone serving ${MEDIA_ENGINE_DOMAIN}.
# DO NOT use the global Cloudflare API key. Leave blank if you're
# on the default HTTP-01 single-cert path.
CLOUDFLARE_API_TOKEN=
