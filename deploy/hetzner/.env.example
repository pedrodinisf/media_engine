# media_engine — Hetzner deploy compose-level environment.
#
# Materialized to deploy/hetzner/.env by bootstrap.sh (chmod 600).
# Loaded by docker-compose via the implicit project .env file. Only
# non-secret operational config goes here; API keys live in the
# adjacent secrets.env (mounted into the container).

# ─── Network ────────────────────────────────────────────────────
# DNS A-record for this VPS must already point at MEDIA_ENGINE_DOMAIN
# before bootstrap.sh runs (Caddy needs port 80 reachable to complete
# the Let's Encrypt HTTP-01 challenge).
MEDIA_ENGINE_DOMAIN=engine.example.com
MEDIA_ENGINE_ACME_EMAIL=you@example.com

# ─── Postgres ───────────────────────────────────────────────────
# Required. Generate with:  openssl rand -base64 24
POSTGRES_PASSWORD=

# ─── Engine knobs ───────────────────────────────────────────────
# Cap on a single POST /acquire/upload body (in MB). Default 2048.
MEDIA_ENGINE_MAX_UPLOAD_MB=2048
