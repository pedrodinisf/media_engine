{
  "name": "media-engine-web",
  "version": "0.6.2",
  "private": true,
  "type": "module",
  "description": "Phase 6 local-first web UI for media_engine. Bundled at media_engine/web/dist/, served by `med web start` (FastAPI StaticFiles at /ui).",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-static": "^3.0.5",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0-beta.3",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/svelte": "^5.2.4",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^22.7.0",
    "jsdom": "^25.0.1",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.5",
    "tailwindcss": "^4.0.0-beta.3",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@11.2.2",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/svelte": "^1.5.2",
    "codemirror": "^6.0.2",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "layerchart": "^1.0.13",
    "yaml": "^2.9.0"
  }
}
